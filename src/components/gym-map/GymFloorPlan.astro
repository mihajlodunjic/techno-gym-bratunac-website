---
import { gymFloorPlan, type GymLandmark, type GymMachine } from "@/data/gymFloorPlan";

const { viewBox, wallPaths, landmarks, machines } = gymFloorPlan;

const centerX = (item: GymLandmark | GymMachine) => item.x + item.width / 2;
const centerY = (item: GymLandmark | GymMachine) => item.y + item.height / 2;

const transformFor = (item: GymLandmark | GymMachine) =>
  item.rotation
    ? `rotate(${item.rotation} ${centerX(item)} ${centerY(item)})`
    : undefined;

const labelTransformFor = (item: GymLandmark | GymMachine) =>
  item.labelRotation
    ? `rotate(${item.labelRotation} ${centerX(item)} ${centerY(item)})`
    : undefined;
---

<svg
  class="gym-floor-plan"
  viewBox={`0 0 ${viewBox.width} ${viewBox.height}`}
  role="img"
  aria-labelledby="gym-floor-plan-title gym-floor-plan-desc"
  data-gym-map-svg
>
  <title id="gym-floor-plan-title">Plan prostora Techno Gym teretane</title>
  <desc id="gym-floor-plan-desc">
    Interaktivni plan prikazuje ulaz, pult, bučice, sprave M1 do M19 i četiri cardio trake.
  </desc>

  <defs>
    <linearGradient id="gym-map-gradient" x1="0" y1="0" x2="1" y2="0.88">
      <stop offset="0%" stop-color="#FFD65A" />
      <stop offset="48%" stop-color="#F8B746" />
      <stop offset="100%" stop-color="#EF9145" />
    </linearGradient>
    <pattern
      id="gym-map-construction-pattern"
      width="176"
      height="176"
      patternUnits="userSpaceOnUse"
    >
      <path d="M0 0H176V176H0Z" fill="none" stroke="currentColor" stroke-width="1" opacity="0.11" />
      <path d="M88 0V176M0 88H176" stroke="currentColor" stroke-width="1" opacity="0.06" />
    </pattern>
  </defs>

  <rect class="gym-floor-plan__paper" x="0" y="0" width={viewBox.width} height={viewBox.height}></rect>
  <rect class="gym-floor-plan__texture" x="0" y="0" width={viewBox.width} height={viewBox.height}></rect>

  <g class="gym-floor-plan__construction" aria-hidden="true">
    <rect x="68" y="764" width="210" height="170" />
    <rect x="100" y="912" width="185" height="124" />
    <rect x="157" y="19" width="136" height="216" />
    <rect x="1142" y="182" width="168" height="154" />
    <rect x="1250" y="952" width="130" height="96" />
  </g>

  <g class="gym-floor-plan__walls" aria-hidden="true">
    {wallPaths.map((wall) => <path d={wall.d} />)}
  </g>

  <g class="gym-floor-plan__landmarks" aria-hidden="true">
    {landmarks.map((landmark) => (
      <g data-landmark-id={landmark.id} transform={transformFor(landmark)}>
        <rect
          x={landmark.x}
          y={landmark.y}
          width={landmark.width}
          height={landmark.height}
        />
        <text
          class="gym-floor-plan__landmark-label"
          x={centerX(landmark)}
          y={centerY(landmark)}
          transform={labelTransformFor(landmark)}
          dominant-baseline="middle"
          text-anchor="middle"
        >
          {landmark.label}
        </text>
      </g>
    ))}
  </g>

  <g class="gym-floor-plan__machines">
    {machines.map((item) => {
      const padding = item.touchPadding ?? 8;
      return (
        <g
          class="gym-floor-plan__machine"
          role="button"
          tabindex="0"
          aria-label={`${item.id.toUpperCase()}, ${item.name}`}
          aria-pressed="false"
          aria-expanded="false"
          aria-controls="gym-map-popover"
          data-machine
          data-machine-id={item.id}
          data-machine-label={item.label}
          data-machine-name={item.name}
          data-machine-category={item.category}
          data-machine-image={item.image}
          data-machine-image-alt={item.imageAlt}
          transform={transformFor(item)}
        >
          <rect
            class="gym-floor-plan__touch-zone"
            x={item.x - padding}
            y={item.y - padding}
            width={item.width + padding * 2}
            height={item.height + padding * 2}
          />
          <rect
            class="gym-floor-plan__machine-rect"
            x={item.x}
            y={item.y}
            width={item.width}
            height={item.height}
          />
          <text
            class="gym-floor-plan__machine-label"
            x={centerX(item)}
            y={centerY(item)}
            transform={labelTransformFor(item)}
            dominant-baseline="middle"
            text-anchor="middle"
          >
            {item.label}
          </text>
        </g>
      );
    })}
  </g>
</svg>

<style>
  .gym-floor-plan {
    display: block;
    inline-size: 100%;
    block-size: auto;
    background: var(--color-amber);
  }

  .gym-floor-plan__paper {
    fill: url("#gym-map-gradient");
  }

  .gym-floor-plan__texture {
    color: rgba(23, 23, 20, 0.42);
    fill: url("#gym-map-construction-pattern");
    opacity: 0.62;
  }

  .gym-floor-plan__construction rect {
    fill: none;
    stroke: rgba(255, 253, 247, 0.22);
    stroke-width: 1;
  }

  .gym-floor-plan__walls path {
    fill: none;
    stroke: var(--color-ink);
    stroke-width: 7;
    stroke-linecap: square;
    stroke-linejoin: miter;
  }

  .gym-floor-plan__landmarks rect {
    fill: rgba(255, 253, 247, 0.48);
    stroke: var(--color-ink);
    stroke-width: 5;
  }

  .gym-floor-plan text {
    fill: var(--color-ink);
    font-family: var(--font-display);
    font-weight: 800;
    letter-spacing: -0.02em;
    pointer-events: none;
    user-select: none;
  }

  .gym-floor-plan__machine-label {
    font-size: 42px;
  }

  .gym-floor-plan__landmark-label {
    font-size: 38px;
  }

  .gym-floor-plan [data-landmark-id="bucice"] .gym-floor-plan__landmark-label {
    font-size: 32px;
  }

  .gym-floor-plan__machine {
    cursor: pointer;
    outline: none;
  }

  .gym-floor-plan__touch-zone {
    fill: transparent;
    pointer-events: all;
  }

  .gym-floor-plan__machine-rect {
    fill: rgba(255, 253, 247, 0.58);
    stroke: var(--color-ink);
    stroke-width: 4;
    transition:
      fill var(--transition-fast),
      stroke var(--transition-fast),
      stroke-width var(--transition-fast),
      transform var(--transition-fast);
  }

  .gym-floor-plan__machine:hover .gym-floor-plan__machine-rect,
  .gym-floor-plan__machine:focus-visible .gym-floor-plan__machine-rect,
  .gym-floor-plan__machine[data-active="true"] .gym-floor-plan__machine-rect {
    fill: var(--color-ink);
    stroke: var(--color-paper-strong);
    stroke-width: 8;
  }

  .gym-floor-plan__machine:hover .gym-floor-plan__machine-label,
  .gym-floor-plan__machine:focus-visible .gym-floor-plan__machine-label,
  .gym-floor-plan__machine[data-active="true"] .gym-floor-plan__machine-label {
    fill: var(--color-paper-strong);
  }

  .gym-floor-plan__machine:focus-visible .gym-floor-plan__machine-rect {
    stroke: var(--color-amber-light);
  }

  .gym-floor-plan__machine:focus-visible {
    filter: none;
  }

  @media (max-width: 30rem) {
    .gym-floor-plan__texture {
      opacity: 0.38;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .gym-floor-plan__machine-rect {
      transition: none;
    }
  }
</style>
