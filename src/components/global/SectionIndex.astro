---
interface Props {
  number: string;
  label: string;
}

const { number, label } = Astro.props;
---

<p class="section-index eyebrow">
  <span class="section-index__number">{number}</span>
  <span class="section-index__label">/ {label}</span>
</p>

<style>
  .section-index {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    color: var(--color-text-muted);
  }

  .section-index__number {
    color: var(--color-ink);
  }
</style>
