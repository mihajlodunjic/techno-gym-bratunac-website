---
interface Props {
  href: string;
  label: string;
  variant?: "primary" | "inline";
  external?: boolean;
  ariaLabel?: string;
}

const {
  href,
  label,
  variant = "inline",
  external = false,
  ariaLabel
} = Astro.props;
---

<a
  class:list={[variant === "primary" ? "button-link" : "inline-link"]}
  href={href}
  aria-label={ariaLabel}
  target={external ? "_blank" : undefined}
  rel={external ? "noreferrer" : undefined}
>
  <span>{label}</span>
  <svg
    aria-hidden="true"
    width="14"
    height="14"
    viewBox="0 0 14 14"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <path
      d="M2 7H12M12 7L7.5 2.5M12 7L7.5 11.5"
      stroke="currentColor"
      stroke-width="1.4"
      stroke-linecap="square"
      stroke-linejoin="miter"
    ></path>
  </svg>
</a>
