---
import ActionLink from "@/components/global/ActionLink.astro";
import SectionIndex from "@/components/global/SectionIndex.astro";

interface Props {
  showAction?: boolean;
  indexNumber?: string;
}

const { showAction = true, indexNumber = "05" } = Astro.props;
---

<section class="hygiene-notice section" id="pravila">
  <div class="site-container">
    <div class="hygiene-notice__panel panel panel--ink">
      <SectionIndex number={indexNumber} label="PRAVILA" />
      <div class="hygiene-notice__status">
        <span aria-hidden="true"></span>
        <p class="eyebrow">Obavezno pravilo</p>
      </div>

      <h2>Čiste patike. Čista oprema. Čist prostor.</h2>
      <p>
        Za trening su obavezne čiste patike i čista sportska oprema. Zaposleni
        mogu zamoliti člana koji ne poštuje pravilo da napusti prostor.
      </p>

      {showAction && (
        <ActionLink
          href="/radno-vrijeme-i-pravila/"
          label="Informacije prije dolaska"
        />
      )}
    </div>
  </div>
</section>

<style>
  .hygiene-notice {
    background: var(--color-ink);
    color: var(--color-paper-strong);
  }

  .hygiene-notice__panel {
    padding: clamp(1.5rem, 4vw, 2.5rem);
    display: grid;
    gap: 1rem;
    border-color: rgba(255, 253, 247, 0.24);
  }

  .hygiene-notice :global(.section-index),
  .hygiene-notice :global(.section-index__number) {
    color: var(--color-paper-strong);
  }

  .hygiene-notice__status {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
  }

  .hygiene-notice__status span {
    inline-size: 0.8rem;
    block-size: 0.8rem;
    background: var(--color-success);
    border-radius: 50%;
    flex: none;
  }

  .hygiene-notice h2 {
    font-size: clamp(2.6rem, 7vw, 5.8rem);
    line-height: 0.9;
    letter-spacing: -0.035em;
    text-transform: uppercase;
  }

  .hygiene-notice p {
    max-width: 44rem;
    font-size: var(--lead-size);
  }

  .hygiene-notice :global(.inline-link) {
    color: var(--color-paper-strong);
  }
</style>
