---
import ActionLink from "@/components/global/ActionLink.astro";
import SectionIndex from "@/components/global/SectionIndex.astro";
---

<section class="space-atmosphere section" id="prostor">
  <div class="site-container space-atmosphere__grid">
    <div class="space-atmosphere__copy">
      <SectionIndex number="03" label="PROSTOR" />
      <h2 class="section-title">Prijatan prostor za svakodnevni trening</h2>
      <p class="section-lead">
        Posjetioci opisuju Techno Gym kao prijatan i ušuškan prostor sa dosta
        prirodnog svjetla.
      </p>
      <ActionLink href="/oprema-i-prostor/" label="Pogledaj prostor" />
    </div>
  </div>
</section>

<style>
  .space-atmosphere {
    border-top: var(--border-thin);
  }

  .space-atmosphere__grid {
    display: grid;
    gap: 1rem;
  }

  .space-atmosphere__copy {
    max-width: 48rem;
    display: grid;
    gap: 1rem;
  }
</style>
