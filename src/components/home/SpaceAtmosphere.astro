---
import ActionLink from "@/components/global/ActionLink.astro";
import SectionIndex from "@/components/global/SectionIndex.astro";
---

<section class="space-atmosphere section" id="prostor">
  <div class="site-container space-atmosphere__grid">
    <div class="space-atmosphere__title">
      <SectionIndex number="03" label="PROSTOR" />
      <h2 class="section-title">Prostor sa prirodnim svjetlom</h2>
    </div>

    <div class="space-atmosphere__body">
      <article class="space-atmosphere__statement panel">
        <p class="eyebrow">DOSTA PRIRODNOG SVJETLA</p>
        <p>
          Prema utiscima posjetilaca, prostor je ušuškan i prijatan za trening,
          sa dosta prirodnog svjetla. Taj mirniji ton je važan kontrast preciznoj
          opremi i gustim informacijama na ostatku stranice.
        </p>
      </article>

      <article class="space-atmosphere__notes panel panel--ink">
        <p class="eyebrow">SVAKODNEVNI RITAM</p>
        <ul role="list">
          <li>Prijatan i direktan lokalni karakter</li>
          <li>Bez lažnih statistika i bez generičkih obećanja</li>
          <li>Trening svojim tempom tokom cijele sedmice</li>
        </ul>
      </article>
    </div>

    <div class="space-atmosphere__action">
      <ActionLink href="/oprema-i-prostor/" label="Pogledaj prostor" />
    </div>
  </div>
</section>

<style>
  .space-atmosphere {
    border-top: var(--border-thin);
  }

  .space-atmosphere__grid {
    display: grid;
    gap: 1.25rem;
  }

  .space-atmosphere__title,
  .space-atmosphere__body,
  .space-atmosphere__action {
    display: grid;
    gap: 1rem;
  }

  .space-atmosphere__statement,
  .space-atmosphere__notes {
    padding: 1.25rem;
    display: grid;
    gap: 0.8rem;
  }

  .space-atmosphere__notes ul {
    list-style: none;
    display: grid;
    gap: 0.65rem;
  }

  .space-atmosphere__notes li {
    padding-bottom: 0.65rem;
    border-bottom: 1px solid rgba(255, 253, 247, 0.2);
  }

  .space-atmosphere__notes li:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  @media (min-width: 48rem) {
    .space-atmosphere__body {
      grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
    }
  }

  @media (min-width: 64rem) {
    .space-atmosphere__grid {
      grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.2fr) auto;
      align-items: start;
    }
  }
</style>
