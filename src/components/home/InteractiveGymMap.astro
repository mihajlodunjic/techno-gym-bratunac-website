---
import SectionIndex from "@/components/global/SectionIndex.astro";
import GymFloorPlan from "@/components/gym-map/GymFloorPlan.astro";
import MachinePopover from "@/components/gym-map/MachinePopover.astro";
import MapControls from "@/components/gym-map/MapControls.astro";
import { gymFloorPlan } from "@/data/gymFloorPlan";
---

<section class="interactive-gym-map" id="raspored-sprava" data-gym-map>
  <div class="site-container interactive-gym-map__inner">
    <header class="interactive-gym-map__header">
      <div class="interactive-gym-map__copy">
        <SectionIndex number="02" label="RASPORED SPRAVA" />
        <h2 class="section-title">Istraži prostor</h2>
        <p class="section-lead interactive-gym-map__hint interactive-gym-map__hint--desktop">
          Pređi pokazivačem preko oznake sprave ili je dodirni na telefonu.
        </p>
        <p class="section-lead interactive-gym-map__hint interactive-gym-map__hint--mobile">
          Dodirni spravu da vidiš njen naziv. Prevuci plan za pregled cijelog prostora.
        </p>
      </div>
      <MapControls />
    </header>

    <div class="interactive-gym-map__stage" data-gym-map-stage>
      <div
        class="interactive-gym-map__scroll"
        tabindex="0"
        aria-label="Pomični plan prostora teretane"
        data-gym-map-scroll
      >
        <div
          class="interactive-gym-map__canvas"
          style={`--map-ratio: ${gymFloorPlan.viewBox.width} / ${gymFloorPlan.viewBox.height};`}
          data-gym-map-canvas
        >
          <GymFloorPlan />
        </div>
      </div>

      <p class="interactive-gym-map__pan-note">Prevuci za pregled prostora</p>
      <MachinePopover />
    </div>

    <div class="visually-hidden">
      <h3>Lista sprava na planu</h3>
      <ul>
        {gymFloorPlan.machines.map((machine) => (
          <li>{machine.id.toUpperCase()} — {machine.name}</li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .interactive-gym-map {
    min-height: 100svh;
    padding-block: clamp(3rem, 5vw, 5.5rem);
    border-top: var(--border-thin);
    background:
      linear-gradient(90deg, rgba(23, 23, 20, 0.05) 1px, transparent 1px),
      var(--color-paper);
    background-size: 4.5rem 4.5rem;
  }

  .interactive-gym-map__inner {
    min-height: calc(100svh - clamp(6rem, 10vw, 11rem));
    display: grid;
    grid-template-rows: auto minmax(0, 1fr);
    gap: clamp(0.85rem, 1.6vw, 1.25rem);
  }

  .interactive-gym-map__header {
    display: grid;
    gap: 1rem;
    align-items: end;
  }

  .interactive-gym-map__copy {
    display: grid;
    gap: 0.65rem;
  }

  .interactive-gym-map__copy :global(.section-title) {
    font-size: clamp(3rem, 7vw, 6.5rem);
    line-height: 0.86;
  }

  .interactive-gym-map__hint {
    margin: 0;
    font-size: clamp(1rem, 1.6vw, 1.25rem);
  }

  .interactive-gym-map__hint--mobile,
  .interactive-gym-map__pan-note {
    display: none;
  }

  .interactive-gym-map__stage {
    position: relative;
    min-width: 0;
    display: grid;
    gap: 0.65rem;
  }

  .interactive-gym-map__scroll {
    min-width: 0;
    min-height: 0;
    border: var(--border-strong);
    background: var(--color-amber);
    overflow: auto;
    overscroll-behavior: contain;
  }

  .interactive-gym-map__canvas {
    width: 100%;
    min-width: 42.5rem;
    aspect-ratio: var(--map-ratio);
  }

  .interactive-gym-map__pan-note {
    margin: 0;
    color: var(--color-text-muted);
    font-weight: 700;
  }

  @media (min-width: 64rem) {
    .interactive-gym-map {
      min-height: 100vh;
    }

    .interactive-gym-map__inner {
      min-height: calc(100vh - clamp(6rem, 10vw, 11rem));
    }

    .interactive-gym-map__header {
      grid-template-columns: minmax(0, 1fr) auto;
    }

    .interactive-gym-map__stage {
      justify-items: center;
    }

    .interactive-gym-map__scroll {
      width: min(92%, 88rem);
      overflow: visible;
    }

    .interactive-gym-map__canvas {
      width: 100%;
      min-width: 0;
    }
  }

  @media (max-width: 63.9375rem), (hover: none), (pointer: coarse) {
    .interactive-gym-map {
      padding-block: clamp(2rem, 7vw, 4rem);
    }

    .interactive-gym-map__inner {
      min-height: calc(100svh - clamp(4rem, 14vw, 8rem));
    }

    .interactive-gym-map__hint--desktop {
      display: none;
    }

    .interactive-gym-map__hint--mobile,
    .interactive-gym-map__pan-note {
      display: block;
    }

    .interactive-gym-map__stage {
      min-height: 0;
    }

    .interactive-gym-map__scroll {
      height: min(66svh, 42rem);
      touch-action: pan-x pan-y;
    }

    .interactive-gym-map__canvas {
      width: 68rem;
      max-width: none;
      min-width: 42.5rem;
    }
  }

  @media (max-width: 30rem) {
    .interactive-gym-map__scroll {
      height: min(62svh, 36rem);
    }
  }
</style>
